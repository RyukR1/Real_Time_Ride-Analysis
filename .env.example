# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=ride_events

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ride_analytics

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# S3 Configuration (for Iceberg)
AWS_REGION=us-east-1
S3_BUCKET=ride-analytics-bucket
S3_PATH=s3://ride-analytics-bucket/iceberg/

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_APP_NAME=RideAnalyticsPipeline

# Data Generation
NUM_DRIVERS=50
EVENTS_PER_SECOND=100
CITY_CENTER_LAT=40.7128
CITY_CENTER_LON=-74.0060
CITY_RADIUS_KM=50

# Processing
WINDOW_DURATION_MINUTES=5
SURGE_THRESHOLD=100
WATERMARK_DELAY_SECONDS=120

# Feature Flags
ENABLE_DATA_QUALITY_CHECKS=true
DEBUG_MODE=false
